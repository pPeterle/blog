---
import AdjacentPostsBar from '@/components/AdjacentPostsBar.astro'
import PostComments from '@/components/PostComments.astro'
import TagsBar from '@/components/TagsBar.astro'
import ToC from '@/components/ToC.astro'
import PageLayout, {
  type Props as PageLayoutProps
} from '@/layouts/PageLayout.astro'
import HeadingAnchorsPlugin from '@/plugins/HeadingAnchorsPlugin.astro'
import { toDateString } from '@/util'
import { resolveTags } from '@/util/tags'
import { render, type CollectionEntry } from 'astro:content'

export interface Props {
  post: CollectionEntry<'posts'>
}

const { post } = Astro.props

const {
  Content,
  remarkPluginFrontmatter: { readingTime },
  headings
} = await render(post)

const frontmatter: PageLayoutProps['frontmatter'] = {
  ...post.data,
  openGraphImage: post.data.openGraphImage || `/posts/${post.id}.png`,
  activeHeaderLink: 'Blog',
  scrollProgress: true
}
---

<PageLayout {frontmatter}>
  <div slot="top" class="mt-4">
    <a href="/posts/" class="clickable flex w-fit items-center gap-1">
      <span class="iconify tabler--arrow-left text-xl"></span>
      Back to all posts
    </a>
  </div>

  <h1 class="mt-2 mb-2 sm:my-4">{frontmatter.title}</h1>
  <TagsBar tags={resolveTags(post.data.tags)} />

  <div class="mt-4">
    <span class="opacity-75"
      >Published on <time datetime={post.data.publishedDate.toISOString()}
        >{toDateString(post.data.publishedDate)}</time
      > by</span
    >
    <a class="clickable" href={`/authors/${post.data.author}/`}
      >{post.data.author}</a
    > · <span class="whitespace-nowrap opacity-75">{readingTime} </span>
  </div>

  {
    !!post.data.showToC && (
      <div
        slot="aside"
        class="border-accent mt-24 hidden border-r pr-4 opacity-75 transition duration-500 ease-in-out hover:opacity-100 2xl:block"
      >
        <ToC {headings} open />
      </div>
    )
  }{
    !!post.data.showToC && (
      <div class="mt-8 w-fit rounded-sm border 2xl:hidden">
        <ToC {headings} />
      </div>
    )
  }

  <article data-pagefind-body>
    <Content />
  </article>

  <PostComments />

  <AdjacentPostsBar {post} slot="bottom" />
  <HeadingAnchorsPlugin />
</PageLayout>

<style is:global>
  .prose pre.mermaid {
    background: transparent;
    color: inherit;
    padding: 0;
    margin: 1.5em 0;
    text-align: center;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    white-space: normal;
  }

  .prose pre.mermaid svg {
    max-width: 100% !important;
    width: 100% !important;
    height: auto !important;
    display: block;
    margin: 0 auto;
  }
</style>

<script>
  import mermaid from 'mermaid'

  const getCssVar = (name: string) =>
    getComputedStyle(document.documentElement).getPropertyValue(name).trim()

  const rgbVar = (name: string) => {
    const v = getCssVar(name)
    return v ? `rgb(${v})` : ''
  }

  const render = () => {
    const isDark =
      document.documentElement.getAttribute('data-mode') === 'dark'

    const accent = rgbVar('--accent') || (isDark ? '#fff' : '#000')
    const bg = rgbVar('--accent-bg') || (isDark ? '#000' : '#fff')

    mermaid.initialize({
      startOnLoad: false,
      theme: 'base',
      securityLevel: 'loose',
      themeVariables: {
        background: bg,
        primaryColor: bg,
        primaryTextColor: accent,
        primaryBorderColor: accent,
        secondaryColor: bg,
        secondaryTextColor: accent,
        secondaryBorderColor: accent,
        tertiaryColor: bg,
        tertiaryTextColor: accent,
        tertiaryBorderColor: accent,
        lineColor: accent,
        textColor: accent,
        mainBkg: bg,
        nodeBorder: accent,
        clusterBkg: bg,
        clusterBorder: accent,
        edgeLabelBackground: bg,
        labelTextColor: accent,
        noteTextColor: accent,
        noteBkgColor: bg,
        noteBorderColor: accent
      },
      flowchart: { htmlLabels: true, curve: 'basis' }
    })

    document.querySelectorAll<HTMLElement>('pre.mermaid').forEach((el) => {
      el.removeAttribute('data-processed')
      const original = el.getAttribute('data-mermaid-source')
      if (original) el.textContent = original
      else el.setAttribute('data-mermaid-source', el.textContent || '')
    })

    mermaid.run({ querySelector: 'pre.mermaid' }).then(() => {
      document.querySelectorAll<SVGElement>('pre.mermaid svg').forEach((svg) => {
        svg.removeAttribute('width')
        svg.removeAttribute('height')
        svg.style.maxWidth = '100%'
        svg.style.width = '100%'
        svg.style.height = 'auto'
      })
    })
  }

  render()

  const observer = new MutationObserver((mutations) => {
    if (mutations.some((m) => m.attributeName === 'data-mode')) render()
  })

  observer.observe(document.documentElement, { attributes: true })
</script>
